{
  "name": "engram-spira",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --filter @engram/api dev",
    "dev:web": "bun run --filter @engram/web dev",
    "dev": "bun run --filter '*' dev",
    "typecheck": "bun run --filter @engram/api typecheck && bun run --filter @engram/web typecheck",
    "db:generate": "bun run --filter @engram/api db:generate",
    "db:migrate": "bun run --filter @engram/api db:migrate",
    "db:seed": "bun run --filter @engram/api db:seed",
    "db:studio": "bun run --filter @engram/api db:studio",
    "docs:c4": "docker compose --profile docs up structurizr",
    "docs:export": "bun run scripts/docs-export.ts",
    "docs:sync": "bun run scripts/docs-sync.ts"
  },
  "dependencies": {
    "three": "^0.183.2",
    "web": "^0.0.2"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "bun-types": "^1.3.10"
  }
}
